Cell[BoxData[
 RowBox[{
  RowBox[{"rMS", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "/.", 
           RowBox[{"\"\<OS\>\"", "\[Rule]", "\"\<MS_SM\>\""}]}], ")"}], 
         "\[Rule]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "2", "]"}], "]"}], "/.", 
               RowBox[{"TAGsusy", "\[Rule]", "1"}]}], "/.", 
              RowBox[{"TAGthdm", "\[Rule]", "1"}]}], "/.", 
             RowBox[{
              RowBox[{"B0exp", "[", 
               RowBox[{"o_", ",", "m__"}], "]"}], "\[RuleDelayed]", 
              RowBox[{"B0expq", "[", 
               RowBox[{"o", ",", 
                RowBox[{"Sequence", "@@", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"{", "m", "}"}], "/.", 
                   RowBox[{
                    RowBox[{"(", "0", ")"}], "\[Rule]", "0."}]}], ")"}]}], 
                ",", "Mudim"}], "]"}]}]}], ")"}], "-", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"#", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "/.", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"dMf1s", "[", 
                 RowBox[{"\"\<OS\>\"", ",", "order", ",", "3", ",", "3"}], 
                 "]"}], "\[Rule]", 
                RowBox[{
                 FractionBox["1", "Nc"], "2", " ", "AlfasMT", " ", "k1L", " ",
                  "MTgl", " ", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"-", "1"}], "+", 
                   SuperscriptBox["Nc", "2"]}], ")"}], " ", "\[Pi]", " ", 
                 RowBox[{"(", 
                  RowBox[{"TAGdreg", "-", 
                   RowBox[{"B0expq", "[", 
                    RowBox[{
                    "order", ",", "0.", ",", "0.", ",", "MTgl2", ",", 
                    "QTMS"}], "]"}], "-", 
                   RowBox[{"2", " ", 
                    RowBox[{"Re", "[", 
                    RowBox[{"B0expq", "[", 
                    RowBox[{
                    "order", ",", "MTgl2", ",", "0.", ",", "MTgl2", ",", 
                    "QTMS"}], "]"}], "]"}]}]}], ")"}]}]}], ",", 
               RowBox[{
                RowBox[{"dMf1s", "[", 
                 RowBox[{"\"\<OS\>\"", ",", "order", ",", "4", ",", "3"}], 
                 "]"}], "\[Rule]", 
                RowBox[{
                 FractionBox["1", "Nc"], "2", " ", "AlfasMT", " ", "k1L", " ",
                  "MBgl", " ", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"-", "1"}], "+", 
                   SuperscriptBox["Nc", "2"]}], ")"}], " ", "\[Pi]", " ", 
                 RowBox[{"(", 
                  RowBox[{"TAGdreg", "-", 
                   RowBox[{"B0expq", "[", 
                    RowBox[{
                    "order", ",", "0.", ",", "0.", ",", "MBgl2", ",", 
                    "QBMS"}], "]"}], "-", 
                   RowBox[{"2", " ", 
                    RowBox[{"Re", "[", 
                    RowBox[{"B0expq", "[", 
                    RowBox[{
                    "order", ",", "MBgl2", ",", "0.", ",", "MBgl2", ",", 
                    "QBMS"}], "]"}], "]"}]}]}], ")"}]}]}]}], "}"}]}], ")"}]}],
           ")"}]}], "&"}], ",", 
       RowBox[{"Select", "[", 
        RowBox[{"rOS", ",", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"FreeQ", "[", 
            RowBox[{"#", ",", 
             RowBox[{"_dMf1s", "\[Rule]", "_"}]}], "]"}]}], "&"}]}], "]"}]}], 
      "]"}], "//", 
     RowBox[{
      RowBox[{"Collect", "[", 
       RowBox[{"#", ",", 
        RowBox[{"_B0expq", "|", "_Re"}], ",", "Simplify"}], "]"}], "&"}]}], "//",
     "FullSimplify"}]}], ";"}]], "Input",
