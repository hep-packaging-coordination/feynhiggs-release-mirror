                    RowBox[{"m", "/;", 
                    RowBox[{"m", "=!=", "0"}]}]}], ",", "Infinity"}], "]"}], 
                    "]"}]}]}], "]"}]}], "&&", 
                  RowBox[{"FreeQ", "[", 
                   RowBox[{"#", ",", 
                    RowBox[{
                    RowBox[{"Power", "[", 
                    RowBox[{"_", ",", "n_"}], "]"}], "/;", 
                    RowBox[{"n", ">", "2"}]}]}], "]"}]}], "&"}]}], "]"}], 
              "]"}], ",", 
             RowBox[{
              RowBox[{"#1", "===", 
