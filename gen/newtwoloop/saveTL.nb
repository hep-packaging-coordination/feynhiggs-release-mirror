Cell[BoxData[
 RowBox[{
  RowBox[{"FileSplit", "[", 
   RowBox[{
    RowBox[{"Join", "[", 
     RowBox[{
      RowBox[{"{", "\"\<LOOP(order, -1,1,1)\\n\\n\>\"", "}"}], ",", 
      RowBox[{"Select", "[", 
       RowBox[{"rexpr", ",", 
        RowBox[{
         RowBox[{"FreeQ", "[", 
          RowBox[{"#", ",", 
           RowBox[{"s", "|", "s1", "|", "s2", "|", "i", "|", "j"}]}], "]"}], 
         "&"}]}], "]"}], ",", 
      RowBox[{"{", "\"\<LOOP(hj, 1,4,1)\\n\\n\>\"", "}"}], ",", 
      RowBox[{"Select", "[", 
       RowBox[{"rexpr", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"!", 
           RowBox[{"FreeQ", "[", 
            RowBox[{"#", ",", "i"}], "]"}]}], "&&", 
          RowBox[{"FreeQ", "[", 
           RowBox[{"#", ",", 
            RowBox[{"s", "|", "s1", "|", "s2"}]}], "]"}]}], "&"}]}], "]"}], 
      ",", 
      RowBox[{"{", "\"\<ENDLOOP(hj)\\n\\n\>\"", "}"}], ",", 
      RowBox[{"{", "\"\<LOOP(s, 1,2,1)\\n\\n\>\"", "}"}], ",", 
      RowBox[{"Select", "[", 
       RowBox[{"rexpr", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"!", 
           RowBox[{"FreeQ", "[", 
            RowBox[{"#", ",", "s"}], "]"}]}], "&&", 
          RowBox[{"FreeQ", "[", 
           RowBox[{"#", ",", "i"}], "]"}]}], "&"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{
       "\"\<LOOP(hj, 1,4,1)\\n\\n\>\"", ",", 
        "\"\<LOOP(hk, 1,4,1)\\n\\n\>\""}], "}"}], ",", 
      RowBox[{"Select", "[", 
       RowBox[{"rexpr", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"!", 
           RowBox[{"FreeQ", "[", 
            RowBox[{"#", ",", "s"}], "]"}]}], "&&", 
          RowBox[{"!", 
           RowBox[{"FreeQ", "[", 
            RowBox[{"#", ",", "i"}], "]"}]}]}], "&"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{
       "\"\<ENDLOOP(hk)\\n\\n\>\"", ",", "\"\<ENDLOOP(hj)\\n\\n\>\"", ",", 
        "\"\<ENDLOOP(s)\\n\\n\>\""}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
       "\"\<LOOP(s1, 1,2,1)\\n\\n\>\"", ",", 
        "\"\<LOOP(s2, 1,2,1)\\n\\n\>\""}], "}"}], ",", 
      RowBox[{"Select", "[", 
       RowBox[{"rexpr", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"!", 
           RowBox[{"FreeQ", "[", 
            RowBox[{"#", ",", 
             RowBox[{"s1", "|", "s2"}]}], "]"}]}], "&&", 
          RowBox[{"FreeQ", "[", 
           RowBox[{"#", ",", "i"}], "]"}]}], "&"}]}], "]"}], ",", 
      RowBox[{"{", "\"\<LOOP(hj, 1,4,1)\\n\\n\>\"", "}"}], ",", 
      RowBox[{"Select", "[", 
       RowBox[{"rexpr", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"!", 
           RowBox[{"FreeQ", "[", 
            RowBox[{"#", ",", 
             RowBox[{"s1", "|", "s2"}]}], "]"}]}], "&&", 
          RowBox[{"!", 
           RowBox[{"FreeQ", "[", 
            RowBox[{"#", ",", "i"}], "]"}]}]}], "&"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{
       "\"\<ENDLOOP(hj)\\n\\n\>\"", ",", "\"\<ENDLOOP(s2)\\n\\n\>\"", ",", 
        "\"\<ENDLOOP(s1)\\n\\n\>\"", ",", "\"\<ENDLOOP(order)\\n\\n\>\""}], 
       "}"}]}], "]"}], 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"/.", 
       RowBox[{
        RowBox[{"Arg", "[", "x_", "]"}], "\[RuleDelayed]", 
        RowBox[{"ATAN2", "[", 
         RowBox[{
          RowBox[{"Im", "[", "x", "]"}], ",", 
          RowBox[{"Re", "[", "x", "]"}]}], "]"}]}]}], "/.", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"dMSfsq1", "[", 
          RowBox[{"order", ",", "1", ",", "2", ",", "4", ",", "3"}], "]"}], 
         "\[Rule]", 
         RowBox[{"If", "[", 
          RowBox[{"a_", ",", "b_", ",", "c_"}], "]"}]}], ")"}], 
       "\[RuleDelayed]", 
       "\"\<if(abs(USbgl(1,1))**2 .eq. abs(USbgl(1,2))**2) then\n\t\
dMSfsq1(order,1,2,4,3) = (dMsq12Sf1(order,4,3)*exp(cI*\n     &   \
ATAN2(Im(USbgl(1,1)),Re(USbgl(1,1))))+\n     &   \
(dMSfsq1(order,2,2,4,3)-dMsq11Sf1(order,4,3))*exp(cI*\n     &   \
ATAN2(Im(USbgl(1,2)),Re(USbgl(1,2)))))*exp(-(cI*\n     &   \
ATAN2(Im(USbgl(2,2)),Re(USbgl(2,2)))))\[IndentingNewLine]else\n\t\
dMSfsq1(order,1,2,4,3) = (((dMSfsq1(order,1,1,4,3)-\n     &   \
dMSfsq1(order,2,2,4,3))*USbgl(1,1)-\n     &   \
Conjugate(dMsq12Sf1(order,4,3))*USbgl(1,2))*USbglC(2,1)+\n     &   \
dMsq12Sf1(order,4,3)*USbgl(1,1)*USbglC(2,2))/\n     &   \
(Abs(USbgl(1,1))**2-Abs(USbgl(1,2))**2)\n\tendif\n\n\>\""}]}], "*)"}], ",", 
    "\"\<renconst_1L_dep\>\"", ",", "WriteMod"}], "]"}], ";"}]], "Input",
