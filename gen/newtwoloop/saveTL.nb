 RowBox[{
  RowBox[{"newints", "[", "rules_", "]"}], ":=", 
  RowBox[{"generalints", "[", 
   RowBox[{"Flatten", "[", 
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{"Function", "[", 
       RowBox[{"u", ",", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"u", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "/.", "#"}], "&"}], ",", 
          RowBox[{
           RowBox[{"DeleteDuplicates", "[", 
            RowBox[{
             RowBox[{"Union", "[", 
              RowBox[{"Select", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Cases", "[", 
                  RowBox[{
                   RowBox[{"u", "[", 
                    RowBox[{"[", "2", "]"}], "]"}], ",", 
                   RowBox[{
                    RowBox[{"Power", "[", 
                    RowBox[{"x_", ",", "n_"}], "]"}], "\[RuleDelayed]", 
                    RowBox[{"x", "/;", 
                    RowBox[{"n", "<", "0"}]}]}], ",", "Infinity"}], "]"}], "/.",
                  "Deltarules"}], ",", 
                RowBox[{
                 RowBox[{
                  RowBox[{"!", 
                   RowBox[{"FreeQ", "[", 
                    RowBox[{"#", ",", 
                    RowBox[{"Alternatives", "@@", 
                    RowBox[{"Union", "[", 
                    RowBox[{"Cases", "[", 
                    RowBox[{"genints", ",", 
                    RowBox[{
                    RowBox[{"Df", "[", 
                    RowBox[{"_", ",", "m_"}], "]"}], "\[RuleDelayed]", 
                    RowBox[{"m", "/;", 
                    RowBox[{"m", "=!=", "0"}]}]}], ",", "Infinity"}], "]"}], 
                    "]"}]}]}], "]"}]}], "&&", 
                  RowBox[{"FreeQ", "[", 
                   RowBox[{"#", ",", 
                    RowBox[{
                    RowBox[{"Power", "[", 
                    RowBox[{"_", ",", "n_"}], "]"}], "/;", 
                    RowBox[{"n", ">", "2"}]}]}], "]"}]}], "&"}]}], "]"}], 
              "]"}], ",", 
             RowBox[{
              RowBox[{"#1", "===", 
               RowBox[{"-", "#2"}]}], "&"}]}], "]"}], "/.", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"i_", "^", "2"}], "-", 
               RowBox[{"j_", "^", "2"}]}], "\[RuleDelayed]", 
              RowBox[{"j", "\[Rule]", "i"}]}], ",", 
             RowBox[{
              RowBox[{"Delta", "[", 
               RowBox[{
