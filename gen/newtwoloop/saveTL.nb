                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"k", "\[Rule]", "i"}], ",", 
                  RowBox[{"j", "\[Rule]", "0"}]}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"k", "\[Rule]", "j"}], ",", 
                  RowBox[{"i", "\[Rule]", "0"}]}], "}"}]}], "]"}]}], ",", 
             RowBox[{
              RowBox[{"i", ":", 
               RowBox[{"m1", "|", "m2", "|", "m3", "|", "m4", "|", "m5"}]}], 
              "\[RuleDelayed]", 
              RowBox[{"i", "\[Rule]", "0"}]}]}], "}"}]}]}], "]"}]}], "]"}], 
      ",", "rules"}], "]"}], "]"}], "]"}]}]], "Input",
