            RowBox[{"i", "|", "j"}]}], "]"}]}], "&"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{
       "\"\<LOOP(hj, 1,4,1)\\n\\n\>\"", ",", 
