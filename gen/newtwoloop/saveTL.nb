                 RowBox[{"Cases", "[", 
                  RowBox[{
                   RowBox[{"u", "[", 
                    RowBox[{"[", "2", "]"}], "]"}], ",", 
                   RowBox[{
                    RowBox[{"Power", "[", 
                    RowBox[{"x_", ",", "n_"}], "]"}], "\[RuleDelayed]", 
                    RowBox[{"x", "/;", 
                    RowBox[{"n", "<", "0"}]}]}], ",", "Infinity"}], "]"}], "/.",
                  "Deltarules"}], ",", 
                RowBox[{
                 RowBox[{
                  RowBox[{"!", 
                   RowBox[{"FreeQ", "[", 
                    RowBox[{"#", ",", 
