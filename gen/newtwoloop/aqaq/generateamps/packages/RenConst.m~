expB00[expr_] := expr /. ToOldBRules /.
  B00[p_, m0_, m1_] :> 1/2/(3 - 2 del) (A0[m1] +
    2 m0 B0[p, m0, m1] + (m0 - m1 + p) B1[p, m0, m1]) /.
  A0[m_] :> m B0[0, 0, m] /.
  B0[0, m_, m_] :> (1 - del) B0[0, 0, m]

(*
ht = cTAG[Yuk] MT/v/SB
hb = cTAG[Yuk] MB/v/CB
*)
MTMW = cTAG[Yuk] SB ht Sqrt[2] SW/EL;
MBMW = cTAG[Yuk] CB hb Sqrt[2] SW/EL;

glcoup[expr_] := Collect[
  expr /. {
    i:PaVeIntegral[__] :> i, d_DiagMark :> d,
    MT2 -> MTMW^2 MW2,
    MT -> MTMW MW,
    MB2 -> MBMW^2 MW2,
    MB -> MBMW MW,
    m:MSf2[1|2,3,3] :> MTMW^2 MW2/MT2 m,
    m:MSf[1|2,3,3] :> MTMW MW/MT m,
    m:MSf2[1|2,4,3] :> MBMW^2 MW2/MB2 m,
    m:MSf[1|2,4,3] :> MBMW MW/MB m},
  {_cTAG}, MagicSimplify[#, Feedback -> False]& ]

RenConst[dMWsq1MW2] :=
