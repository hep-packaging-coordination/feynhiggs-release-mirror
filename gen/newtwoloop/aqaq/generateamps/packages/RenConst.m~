       SW, CW, SW2, CW2, MGl, MT, MB, _MSf, MGl2, MT2, MB2, _MSf2, UCSf[1 | 2, 1 | 2, __]}];

RealQ[Times[x_, y__]] := RealQ[x] && RealQ[Times[y]];
RealQ[Power[x_, i_?IntegerQ]] := RealQ[x];

resimp[x_] := x /. (a : Re | Im)[y_] :> a[Expand[y]] /.
      (a : Re | Im)[y_] :> a[Numerator[y]]/Denominator[y] /; RealQ[Expand[Denominator[y]]] /.
      (a : Re | Im)[y_] :> Refine[a[y]];

rcsimp[x_] :=
Block[ {pre = x},
  If[ FreeQ[pre, _cTAG],
    pre = pre /. {
      1/MW -> MTMW/MT, 1/MW2 -> MTMW^2/MT2,
      1/MZ -> CW MTMW/MT, 1/MZ2 -> CW2 MTMW^2/MT2,
      MW -> 0, MW2 -> 0, MZ -> 0, MZ2 -> 0 } ];
  pre = Modify[pre];
(*
  pre = pre /.
    Alfa p_Plus :> Distribute[Alfa p] /; !FreeQ[p, Alfa^_?Negative] /.
    Alfa -> 0;
*)
  pre = resimp @ USfSimplify @ Expand[pre, _USf | _USfC];
  pre
]

rcexp[x_] :=
Block[ {pre = x},
  pre = ExpandDel[pre];
  (*pre = Collect[pre, _DiagMark, DelSeries];*)
  pre = pre /. r:Alternatives@@ (rcs /. RenConstList[RenConst][rclist__] :> rclist) :> RC[r];
  pre = DelSeries[pre];
  pre = TermCollect[pre];
  pre
]


(* introduce switches for OS/DRbar *)

rcmod[dMSfsq1[_, _, 3, __]] = osflag[dMSt1OS]
rcmod[dMSfsq1[_, _, 4, __]] = osflag[dMSb1OS]

rcmod[dMf1[3, __]] = osflag[dMT1OS]
rcmod[dMf1[4, __]] = osflag[dMB1OS]

_rcmod = Identity

osflag[flag_][rc_] := flag rc + (1 - flag) UVDivergentPart[rc]

