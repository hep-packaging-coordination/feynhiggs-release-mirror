#! /bin/sh -x

test $# -ne 2 && {
  cat << _EOF_
Usage:  $0 se cto
simplifies the 'se' 2L self-energy
_EOF_
  exit 1
}

in=m/$1/3-calc.$2
test -f $in || exit 1
out=m/$1/4-simp.$2
rm -f $out*

time math -run cto=$2 \
          -run in=\"$in\" \
          -run out=\"$out\" << \_EOF_ > $out.log
AppendTo[$Echo, "stdout"];

PrependTo[$Path, ToFileName[{$HomeDirectory, "Mathematica-PlugIns", "FeynArts-3.9"}]]; (* FeynArts path *)
PrependTo[$Path, ToFileName[{$HomeDirectory, "Mathematica-PlugIns", "FormCalc-9.4"}]]; (* FormCalc path *)
PrependTo[$Path, ToFileName[{$HomeDirectory, "Mathematica-Projekte", "FC2L", "aqaqnew"}]];

<< packages`XtSimplify`;
<< packages`XbSimplify`;
<< packages`U2Simplify`;
<< packages`USfSimplify`;
<< packages`SimplificationDefinitions`;
<< packages`FCSettings`;
<< FormCalc`;
<< FormCalc`ModelSpecific`;

amp = Get[in];

amp = amp /. {
  A0[m_] :> m B0[0, 0, m],
  B0[0, 0, 0] -> 0,
  B0[0, m_, m_] :> (1 - del) B0[0, 0, m],
  B0[0, m0_, m1_] :> (m1 B0[0, 0, m1] - m0 B0[0, 0, m0])/(m1 - m0) } //.
  (int:(T | DT))[Df[ki_, mi_]^ni_. Dfs_., Dfl_: {}] :> int[Dfs, Append[Dfl, {ki, mi, ni}]] /.
  (int:(T | DT))[1, l_] :> Function[funcarg, (int @@ Flatten[MapThread[PadLeft[{}, #3, ToExpression[StringReplace[ToString[#1], "k" -> ""]]] &, funcarg]]) @@
    (Flatten[MapThread[PadLeft[{}, #1, #2] &, {funcarg[[3]], funcarg[[2]]^2}]])][Transpose[l]](* /.
    (int:(T | DT))[i__][m__] :> ToExpression[ToString[int] <> StringJoin @@ ToString /@ {i}][m]*);

amp = Collect[amp, {_cTAG, _B0, T[__][__], _DiagMark}, Check[# /. M0 -> 0, Limit[#, M0 -> 0]] &];

Collect[amp, {_cTAG, _B0, T[__][__], _DiagMark}, MagicSimplify[#, SimpSubExpr -> False] &];

usfrules = Map[#[[1]] :> #[[2]] &, Flatten[Table[{USf[i, j, m__] USfC[k, l, m__], USfSimplify[USf[i, j, m] USfC[k, l, m]]}, {i, 2}, {j, 2}, {k, 2}, {l, 2}], 3]];

amp = Collect[amp, {_cTAG, _B0, T[__][__], _DiagMark}, MagicSimplify[V2Simplify[U2Simplify[Expand[# //. usfrules, _USf | _USfC] //. usfrules]], Feedback -> False, SimpSubExpr -> False] &];

amp = amp  /. {
    MSf2[3,i__] :> MSf2[2,i] - MSf2[1,i],
    MSf2[4,i__] :> MSf2[1,i] + MSf2[2,i],
    MSq2Diff[i_, j_] :> MSf2[i,4,3] - MSf2[j,3,3] };

Put[amp, out];

_EOF_

gzip $out.log

test -f $out

