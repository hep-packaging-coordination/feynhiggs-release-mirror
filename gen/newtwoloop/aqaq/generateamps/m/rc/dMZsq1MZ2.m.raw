             MSf2[Sfe4, 4, 3]]])*((1 + 2*CW2)*USf[Sfe4, 1, 4, 3]*
           USfC[Sfe3, 1, 4, 3] - 2*SW2*USf[Sfe4, 2, 4, 3]*USfC[Sfe3, 2, 4, 
            3])*((1 + 2*CW2)*USf[Sfe3, 1, 4, 3]*USfC[Sfe4, 1, 4, 3] - 
          2*SW2*USf[Sfe3, 2, 4, 3]*USfC[Sfe4, 2, 4, 3])))/(-3 + 2*del)))/
   (72*CW2*Pi*SW2))/MZ2
