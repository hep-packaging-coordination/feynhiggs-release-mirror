             MSf2[Sfe4, 3, 3]]])*((1 - 4*CW2)*USf[Sfe4, 1, 3, 3]*
           USfC[Sfe3, 1, 3, 3] + 4*SW2*USf[Sfe4, 2, 3, 3]*USfC[Sfe3, 2, 3, 
            3])*((1 - 4*CW2)*USf[Sfe3, 1, 3, 3]*USfC[Sfe4, 1, 3, 3] + 
          4*SW2*USf[Sfe3, 2, 3, 3]*USfC[Sfe4, 2, 3, 3]) + 
        DiagMark[MSf[Sfe3, 4, 3], MSf[Sfe4, 4, 3]]*
         (MSf2[Sfe4, 4, 3]*Re[B0[0, 0, MSf2[Sfe4, 4, 3]]] + 
          2*MSf2[Sfe3, 4, 3]*Re[B0[0, MSf2[Sfe3, 4, 3], MSf2[Sfe4, 4, 3]]] + 
