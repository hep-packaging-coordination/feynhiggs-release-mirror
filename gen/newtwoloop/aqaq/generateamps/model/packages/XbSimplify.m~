XtSimplify[expr_, usimp_:Identity, b_:True, a_:True] :=
Block[ {pre, MUE, MUEC, MMUE2},
  MMUE2 = MUE MUEC;
  pre = expr /.
    {Af[4, __] -> Ab, AfC[4, __] -> AbC} /.
    If[ b =!= True, {},
      {CB -> Cb, CB2 -> Cb^2, SB -> Sb, SB2 -> Sb^2,
       C2B -> Cb^2 - Sb^2, S2B -> 2 Cb Sb, TB -> Sb/Cb} ] /.
    If[ a =!= True, {},
      {CA -> Ca, CA2 -> Ca^2, SA -> Sa, SA2 -> Sa^2,
       C2A -> Ca^2 - Sa^2, S2A -> 2 Ca Sa} ];
  pre = tc[pre];
  pre = pre /. Plus -> sfplus /.
    p_Plus :> Simplify[p] /; MemberQ[p, _. (Ab | AbC)] /.
    {Cb -> cb, Sb -> sb, Ca -> ca, Sa -> sa} /.
    sftag -> sfsimp;
  pre = tc[pre];
  pre = usimp[pre];
  pre /.
    { cb -> CB, sb -> SB, ca -> CA, sa -> SA,
      cbMUE -> CB MUE, cbMUEC -> CB MUEC,
      sbMUE -> SB MUE, sbMUEC -> SB MUEC,
      cbAb -> CB Ab, cbAbC -> CB AbC,
      sbAb -> SB Ab, sbAbC -> SB AbC,
      caMUE -> CA MUE, caMUEC -> CA MUEC,
      saMUE -> SA MUE, saMUEC -> SA MUEC,
      caAb -> CA Ab, caAbC -> CA AbC,
      saAb -> SA Ab, saAbC -> SA AbC } (* /.
    { SB/CB -> TB, CB/SB -> 1/TB } *)
]


sfplus[p__] :=
  If[ !FreeQ[{p}, Ab | AbC | MUE | MUEC] &&
      Complement[Cases[{p}, _Symbol, {-1}],
        {Cb, Sb, Ca, Sa, Ab, AbC, MUE, MUEC, UCSf, UCSfC,
         SW2, CW2, MW2, MT2, MT}] === {},
    sftag,
    Identity
  ] @ Plus[p]

sftag/: sftag[x_] u:(_UCSf | _UCSfC | _USf | _USfC) := sftag[x u];
sftag/: sftag[x_] sftag[y_] := sftag[x y];
sftag[x_] := sftag[x /. sftag -> Identity] /; !FreeQ[x, sftag]


Attributes[fplus] = {Flat}

splus[n_?Negative, r__] := -fplus@@ (-{n, r})

splus[n_?Negative x_, r__] := -fplus@@ (-{n x, r})

tc[x_] := x /. Plus -> splus /. splus -> fplus //.
  fplus[a_ b_, a_ c_] :> a fplus[b, c] /. fplus -> Plus //.
  a_ b_ + a_ c_ :> a (b + c)

tcs[x_] := FullSimplify[tc[x]]

pr[x_] := (Print[x //InputForm]; x)

sfsimp[s_] := sfsimp[s] = tcs[Expand[tcs[s]]]


ca/: ca MUE = caMUE;
ca/: ca MUEC = caMUEC;
sa/: sa MUE = saMUE;
sa/: sa MUEC = saMUEC;
ca/: ca Ab = caAb;
ca/: ca AbC = caAbC;
sa/: sa Ab = saAb;
sa/: sa AbC = saAbC;

cb/: cb MUE = cbMUE;
cb/: cb MUEC = cbMUEC;
sb/: sb MUE = sbMUE;
sb/: sb MUEC = sbMUEC;
cb/: cb Ab = cbAb;
cb/: cb AbC = cbAbC;
sb/: sb Ab = sbAb;
sb/: sb AbC = sbAbC;


(* XAb = Ab - MUEC SA/CA *)
caAb/: caAb - saMUEC = ca XAb;
caAbC/: caAbC - saMUE = ca XAbC;
saMUEC/: saMUEC - caAb = -ca XAb;
saMUE/: saMUE - caAbC = -ca XAbC;

(* YAb = Ab + MUEC CA/SA *)
saAb/: saAb + caMUEC = sa YAb;
saAbC/: saAbC + caMUE = sa YAbC;

(* Xb = Ab - MUEC TB *)
cbAb/: cbAb - sbMUEC = cb Xb;
cbAbC/: cbAbC - sbMUE = cb XbC;
sbMUEC/: sbMUEC - cbAb = -cb Xb;
sbMUE/: sbMUE - cbAbC = -cb XbC;

(* Yb = Ab + MUEC/TB *)
sbAb/: sbAb + cbMUEC = sb Yb;
sbAbC/: sbAbC + cbMUE = sb YbC;


Conjugate[Ab] ^= AbC;
Conjugate[AbC] ^= Ab;
Conjugate[Xb] ^= XbC;
Conjugate[XbC] ^= Xb;
Conjugate[Yb] ^= YbC;
Conjugate[YbC] ^= Yb;

