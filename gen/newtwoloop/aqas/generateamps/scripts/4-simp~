#! /bin/sh -x

test $# -ne 2 && {
  cat << _EOF_
Usage:  $0 se cto
simplifies the 'se' 2L self-energy
_EOF_
  exit 1
}

in=m/$1/3-calc.$2
test -f $in || exit 1
out=m/$1/4-simp.$2
rm -f $out*

time math -run cto=$2 \
          -run in=\"$in\" \
          -run out=\"$out\" << \_EOF_ > $out.log
AppendTo[$Echo, "stdout"];

PrependTo[$Path, ToFileName[{$HomeDirectory, "Mathematica-PlugIns", "FeynArts-3.9"}]]; (* FeynArts path *)
PrependTo[$Path, ToFileName[{$HomeDirectory, "Mathematica-PlugIns", "FormCalc-9.7"}]]; (* FormCalc path *)
PrependTo[$Path, ToFileName[{$HomeDirectory, "Mathematica-Projekte", "FC2L", "aqas"}]];

<< packages`SimplificationDefinitions`;
<< packages`FCSettings`;
<< FormCalc`;
<< FormCalc`ModelSpecific`;
<< packages`USfSimplify`;
<< packages`FinalSimp`;

SetOptions[Simplify, TimeConstraint -> 20];

amp = Get[in];

amp = amp /. {
  A0[m_] :> m B0[0, 0, m],
  B0[0, 0, 0] -> 0,
  B0[0, m_, m_] :> (1 - del) B0[0, 0, m],
  B0[0, m0_, m1_] :> (m1 B0[0, 0, m1] - m0 B0[0, 0, m0])/(m1 - m0) } //.
  (int:(T | DT))[Df[ki_, mi_]^ni_. Dfs_., Dfl_: {}] :> int[Dfs, Append[Dfl, {ki, mi, ni}]] /.
  (int:(T | DT))[1, l_] :> Function[funcarg, (int @@ Flatten[MapThread[PadLeft[{}, #3, ToExpression[StringReplace[ToString[#1], "k" -> ""]]] &, funcarg]]) @@
    (Flatten[MapThread[PadLeft[{}, #1, #2] &, {funcarg[[3]], funcarg[[2]]^2}]])][Transpose[l]](* /.
    (int:(T | DT))[i__][m__] :> ToExpression[ToString[int] <> StringJoin @@ ToString /@ {i}][m]*);

amp = Collect[amp, {hb^2, ht^2, hb ht, hb, ht, Alfa, Alfas, _DiagMark, _B0, _T[__], _DT[__]},
              ColourSimplify[Expand[#, _SumOver | _SUNTSum | _SUNT]] &];

simp[x_] := simp[x] = MagicSimplify[x, Feedback -> False, SimpSubExpr -> False];
usfsimp[x_] := simp @ USfSimplify @ Expand[x /. Hold -> Identity /. (a : UCSf | UCSfC | UUSf | UUSfC)[ind__] :> USfRev[a[ind]]];

amp = Collect[amp, {hb^2, ht^2, hb ht, hb, ht, Alfa, Alfas, _DiagMark, _B0, _T[__], _DT[__]}, usfsimp];

amp = Collect[amp, {hb^2, ht^2, hb ht, hb, ht, Alfa, Alfas, _DiagMark, _B0, _T[__], _DT[__]}, TermCollect] /.
  p_Plus :> simp[p] /; LeafCount[p] < 100;

amp = Collect[amp, {hb^2, ht^2, hb ht, hb, ht, Alfa, Alfas, _DiagMark, _B0, _T[__], _DT[__]}, simp];

Put[amp, out];

_EOF_

gzip $out.log

test -f $out

