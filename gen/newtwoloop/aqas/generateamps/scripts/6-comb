#! /bin/sh -x

test $# -ne 1 && {
  cat << _EOF_
Usage:  $0 se
puts together the renormalized 'se' 2L self-energy
env DEBUG=i outputs the coefficient of del^i only
_EOF_
  exit 1
}

out=m/$1/6-comb
rm -f $out*

time math -run se=\"$1\" \
          -run out=\"$out\" \
          -run debug=${DEBUG:-0} << \_EOF_ > $out.log
AppendTo[$Echo, "stdout"];


PrependTo[$Path, ToFileName[{$HomeDirectory, "Mathematica-PlugIns", "FeynArts-3.9"}]]; (* FeynArts path *)
PrependTo[$Path, ToFileName[{$HomeDirectory, "Mathematica-PlugIns", "FormCalc-9.7"}]]; (* FormCalc path *)
PrependTo[$Path, ToFileName[{$HomeDirectory, "Mathematica-Projekte", "FC2L", "aqas"}]];

(*<< packages`FinalSimp`;*)
<< packages`FCSettings`;
<< packages`USfSimplify`;

<< packages`ExpandDel`;
<< packages`SimplificationDefinitions`;
<< model/MSSMCT.rc2;

p2 = 0;

get[file_] := Check[(Print["Reading ", file]; Get[file]), Exit[]];

get[name_, cto_] := get @ ToFileName[{"m", name}, "4-simp." <> ToString[cto]];

getamp[name_] := getamp[name] =
  TAG[name, 0] get[name, 0] + TAG[name, 1] get[name, 1];

If[ debug === 0,
  (*TAG[_, i_] := TAG[i];*)
  _TAG = 1,
(* else *)
  inputMA0 = 1;
  inputMHp = 0;
];

Tadh02 := getamp["h0"];
TadHH2 := getamp["HH"];
TadA02 := getamp["A0"];
SEA0A02 := getamp["A0A0"];
SEHmHp2 := getamp["HmHp"];

amp = {
  TAG[se, 0] get[se, 0],
  TAG[se, 1] get[se, 1],
  TAG[se, 2] ct[se]};

Conjugate[DRbarflag] ^= DRbarflag;
Re[DRbarflag] ^= DRbarflag;

rcs = Get/@ FileNames[ToFileName[{"m", "rc"}, "*.m"]] /. RC[i:0 | 1, x_] :> (1 - DRbarflag) RC[i, x];

amp = amp //. Prepend[Cases[rcs, _Rule, {2}], r_RC :> r];

rct = Drop[amp, 1];
zrc = Complement[
  Cases[rct, _RC, Infinity],
  Cases[Expand[rct], _RC, Infinity] ];
amp = amp /. Thread[zrc -> 0];

amp = ExpandDel[amp];

amp = Collect[amp, {hb^2, ht^2, hb ht, hb, ht, Alfa, Alfas, _DiagMark}, DelSeries];

If[debug === 0,
amp[[3]] = (1 - DRbarflag) amp[[3]];
];

DC[debug, x_] := x;
_DC = 0;

If[ debug === 0,
  amp = amp(*FinalSimp[amp]*) (*/. inputMHp -> 1 - inputMA0*),
(* else *)
  amp = amp /. Cases[rcs, _Rule, {4}]
];

collectlist = {Alfas, hb^2, ht^2, hb ht, _B0fin, _B0del, _Tdiv2[__], _Tdiv[__], _Tfin[__], _DTdiv2[__], _DTdiv[__], _DTfin[__], _DiagMark};

usfsimp[x_] := MagicSimplify[USfSimplify[Expand[x /. Hold -> Identity /. (a : UCSf | UCSfC | UUSf | UUSfC)[ind__] :> USfRev[a[ind]], _USf | _USfC]], SimpSubExpr -> False];

amp = Collect[amp, collectlist, usfsimp];

Put[amp, out];

_EOF_

gzip $out.log

test -f $out

