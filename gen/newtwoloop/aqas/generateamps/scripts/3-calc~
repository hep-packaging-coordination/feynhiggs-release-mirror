#! /bin/sh -x

test $# -ne 2 && {
  cat << _EOF_
Usage:  $0 se cto
calculates the 'se' 2L self-energy with TuCalc/FormCalc
_EOF_
  exit 1
}

in=m/$1/2-prep.$2
test -f $in || exit 1
out=m/$1/3-calc.$2
rm -f $out*

case $2 in
0)	# calculation of the 2L self-energies with TuCalc
time math -run se=\"$1\" \
          -run in=\"$in\" \
          -run out=\"$out\" << \_EOF_ > $out.log
AppendTo[$Echo, "stdout"];
$Path = Flatten[{
  ToFileName[{"twocalc"}],
  ToFileName[{"twocalc", "work"}],
  ToFileName[{"twocalc", "TuCalc", "Code"}],
  $Path }];

PrependTo[$Path, ToFileName[{$HomeDirectory, "Mathematica-PlugIns", "FeynArts-3.9"}]]; (* FeynArts path *)
PrependTo[$Path, ToFileName[{$HomeDirectory, "Mathematica-PlugIns", "FormCalc-9.7"}]]; (* FormCalc path *)
PrependTo[$Path, ToFileName[{$HomeDirectory, "Mathematica-Projekte", "FC2L", "aqas"}]];

SEPart = 8;

<< TuCalc`;
$VeryVerbose = 0;
SetOptions[TwoLoop,
  CollectFunction -> 0,
  Dimension -> $D,
  DimReduction -> True];
SetOptions[TwoLoopSum,
  CollectFunction -> 0,
  SelfEnergyPart -> SEPart];
TwoLoopSum[0] = 0;

SetOptions[Simplify, TimeConstraint -> 10];

GG[s_][cto_][fi__][kin_] := GG[s][cto][fi][kin] = Coupling[Unique[]];

amp = TwoLoopSum[Get[in] /. G -> GG];

<< packages`UseSimplePackage`;
<< packages`USfSimplify`;

ints = Check[Get["ints.list"], {}];
intsNew = Cases[amp, _T | _Y, {0, Infinity}] /.
  Y[Den[dfs__] Num[ks__]] :> T[dfs Df[k6, ks]] //. 
  T[Df[ki_, mi_]^ni_. Dfs_., Dfl_: {}] :> T[Dfs, Append[Dfl, {ki, mi, ni}]] /. 
  T[1, l_] :> Function[x, (T @@ Flatten[MapThread[PadLeft[{}, #3, ToExpression[StringReplace[ToString[#1], "k" -> ""]]] &, x]]) @@ (x[[2]]^2)][Transpose[l, {2, 1}]] /. 
  T[i__][m__] :> (T[i][m] /. Flatten[MapThread[{#1 -> ToExpression[StringJoin["m", ToString[#2]]]} &, {#, Range[Length[#]]}] &[Select[DeleteDuplicates[{m}], And @@ Map[Function[u, # =!= u], {0, k1^2, k2^2, k3^2, k4^2, k5^2}] &]]]) /. 
  T[i__, 6][m__, k_^2] :> Y[Den[i][m], Num[k]] // Union;
intsNew = intsNew /.
  Y[Den[ind__][mass__], num_] :> Y[Den[Times @@ MapThread[#1 /. Df[k_]^n_. :> Df[k, #2]^n &, {DeleteCases[Map[Function[rangeind, Df[ToExpression[StringJoin["k", ToString[rangeind]]]]^Count[{ind}, rangeind]], Range[5]], 1], {mass}}]] num] /. 
  T[ind__][mass__] :> T[Times @@ MapThread[#1 /. Df[k_]^n_. :> Df[k, #2]^n &, {DeleteCases[Map[Function[rangeind, Df[ToExpression[StringJoin["k", ToString[rangeind]]]]^Count[{ind}, rangeind]], Range[5]], 1], {mass}}]];
intsNew = Complement[intsNew, ints];
Put[Join[ints, intsNew], "ints.list"];

(* here would be the place for integral reduction *)

(* use TwoCalc first *)
ReduzeRules = Check[Get["reduce.rules"], {}];
ReduzeRulesNew = Map[# -> Simplify[UseSimplePackage[UseSimplePackage[#]] /. dim -> $D /. A0[m_] :> A0[m^2] /. B0[p_, m1_, m2_] :> B0[p, m1^2, m2^2]] &, intsNew];
ReduzeRulesNew = Map[(#[[1]] /. {m1 -> m1_, m2 -> m2_, m3 -> m3_, m4 -> m4_}) -> #[[2]] &, ReduzeRulesNew];
ReduzeRules = Join[ReduzeRules, ReduzeRulesNew];

sortfunc[x_] := 
  Sum[2^((16 - sumind) Count[x, Df[ToExpression[StringJoin["k", ToString[sumind]]], 0], Infinity]), {sumind, 5}] + 
  Sum[2^(10 - sumind1 - sumind2) Boole[Cases[x, Df[ToExpression[StringJoin["k", ToString[sumind1]]], m_] :> m, Infinity] === Cases[x, Df[ToExpression[StringJoin["k", ToString[sumind2]]], m_] :> m, Infinity]], {sumind1, 4}, {sumind2, sumind1 + 1, 5}];

ReduzeRules = Sort[ReduzeRules, sortfunc[#1[[1]]] > sortfunc[#2[[1]]] &];
Put[ReduzeRules, "reduce.rules"];

amp = amp /. ReduzeRules;

intsReduze = Check[Get["intsReduze.list"], {}];
intsReduzeNew = Cases[amp, _T | _Y, {0, Infinity}] /.
  Y[Den[dfs__] Num[ks__]] :> T[dfs Df[k6, ks]] //. 
  T[Df[ki_, mi_]^ni_. Dfs_., Dfl_: {}] :> T[Dfs, Append[Dfl, {ki, mi, ni}]] /. 
  T[1, l_] :> Function[x, (T @@ Flatten[MapThread[PadLeft[{}, #3, ToExpression[StringReplace[ToString[#1], "k" -> ""]]] &, x]]) @@ (x[[2]]^2)][Transpose[l, {2, 1}]] /. 
  T[i__][m__] :> (T[i][m] /. Flatten[MapThread[{#1 -> ToExpression[StringJoin["m", ToString[#2]]]} &, {#, Range[Length[#]]}] &[Select[DeleteDuplicates[{m}], And @@ Map[Function[u, # =!= u], {0, k1^2, k2^2, k3^2, k4^2, k5^2}] &]]]) /. 
  T[i__, 6][m__, k_^2] :> Y[Den[i][m], Num[k]] // Union;
intsReduzeNew = intsReduzeNew /.
  Y[Den[ind__][mass__], num_] :> Y[Den[Times @@ MapThread[#1 /. Df[k_]^n_. :> Df[k, #2]^n &, {DeleteCases[Map[Function[rangeind, Df[ToExpression[StringJoin["k", ToString[rangeind]]]]^Count[{ind}, rangeind]], Range[5]], 1], {mass}}]] num] /. 
  T[ind__][mass__] :> T[Times @@ MapThread[#1 /. Df[k_]^n_. :> Df[k, #2]^n &, {DeleteCases[Map[Function[rangeind, Df[ToExpression[StringJoin["k", ToString[rangeind]]]]^Count[{ind}, rangeind]], Range[5]], 1], {mass}}]];
intsReduzeNew = Complement[intsReduzeNew, intsReduze];
Put[Join[intsReduze, intsReduzeNew], "intsReduze.list"];

(* load rules from Reduze *)
ReduzeRules = Get["Reduze.rules"] /. A0[m_] :> A0[m^2] /. B0[p_, m1_, m2_] :> B0[p, m1^2, m2^2];

amp = amp /. ReduzeRules;

amp = amp /. Pair[Momentum[p], Momentum[p]] -> ExtMomSq /. p2 -> ExtMomSq /. B0[0, 0, 0] -> 0 /. A0[0] -> 0;

Derivative[1, __][T][ExtMomSq, Dfs_] ^:= DT[Dfs];
Derivative[1, __][B0][ExtMomSq, m__] ^:= DB0[ExtMomSq, m];
Derivative[1, __][B1][ExtMomSq, m__] ^:= DB1[ExtMomSq, m];

amp = If[se == "h0h0p" || se == "HHHHp",
         D[amp /. T[Dfs_] :> T[ExtMomSq, Dfs] /; !FreeQ[Dfs, k2 | k5], ExtMomSq] /. T[ExtMomSq, Dfs_] :> T[Dfs],
         amp];

ExtMomSq = Piecewise[{{0, se == "h0h0p"}, {0, se == "HHHHp"}}, 0];

amp = USfSimplify @ amp;

amp = amp /. {$D | dim -> 4 - 2 del};

Put[amp, out];

_EOF_
;;

1)	# calculation of the 1L counterterm diagrams with FormCalc
time math -run se=\"$1\" \
          -run in=\"$in\" \
          -run out=\"$out\" << \_EOF_ > $out.log
AppendTo[$Echo, "stdout"];

PrependTo[$Path, ToFileName[{$HomeDirectory, "Mathematica-PlugIns", "FeynArts-3.9"}]]; (* FeynArts path *)
PrependTo[$Path, ToFileName[{$HomeDirectory, "Mathematica-PlugIns", "FormCalc-9.7"}]]; (* FormCalc path *)
PrependTo[$Path, ToFileName[{$HomeDirectory, "Mathematica-Projekte", "FC2L", "aqas"}]];

<< packages`FCSettings`;

amp = Plus@@ CalcFeynAmp[Get[in]];

amp = amp //. Join[Subexpr[], Abbr[]] /.
  Pair[_k, _k] -> ExtMomSq /. Pair[_e | _ec, _k] -> 0 /. Pair[_e, _ec] -> -1 /. SUNT[_, _] -> 1 /. SUNT[_, _, 0, 0] -> 1/2 /.
  B0[0, 0, 0] -> 0 /. A0[0] -> 0 /. {
  C0i[cc00, 0, 0, 0, m_, m_, m_] :> 1/4 (1 - del) B0[0, 0, m],
  C0i[cc00, 0, 0, 0, m1_, m1_, m2_] :> A0[m1]/(2 (m1 - m2)) + (m1 A0[m1] - m2 A0[m2])/(2 (del - 2) (m1 - m2)^2),
  C0i[cc00, 0, 0, 0, m1_, m2_, m2_] :> -(A0[m2]/(2 (m1 - m2)) + (m1 A0[m1] - m2 A0[m2])/(2 (del - 2) (m1 - m2)^2)),
  C0i[cc00, p_, 0, p_, m1_, m2_, m2_] :> 1/(4 p) (B0[0, 0, m2] m2 - B0[0, 0, m1] m1 + B0[p, m1, m2] (p + m1 - m2)),
  C0i[cc00, 0, p_, p_, m1_, m1_, m2_] :> 1/(4 p) (B0[0, 0, m1] m1 - B0[0, 0, m2] m2 + B0[p, m1, m2] (p - m1 + m2)),
  C0i[cc0, 0, 0, 0, m_, m_, m_] :> -del/(2 m) B0[0, m, m],
  C0i[cc0, 0, p_, p_, m1_, m1_, m2_] :> 1/((m1 + m2 - p)^2 - 4 m1 m2) ((-1 + del) (m1 + m2 - p) B0[0, 0, m1] - 2 (-1 + del) m2 B0[0, 0, m2] + (-1 + 2 del) (m2 - m1 + p) B0[p, m1, m2]),
  C0i[cc0, p_, 0, p_, m1_, m2_, m2_] :> 1/((m1 + m2 - p)^2 - 4 m1 m2) ((-1 + del) (m1 + m2 - p) B0[0, 0, m2] - 2 (-1 + del) m1 B0[0, 0, m1] + (-1 + 2 del) (m1 - m2 + p) B0[p, m1, m2]),
  C0i[cc1, p_, 0, p_, m1_, m2_, m2_] :> 1/p ((-1 + del) B0[0, 0, m2] + B0[p, m1, m2]) + 1/(p ((m1 + m2 - p)^2 - 4 m1 m2)) ((m1 - m2) (2 (-1 + del) m1 B0[0, 0, m1] - (-1 + del) (m1 + m2 - p) B0[0, 0, m2] + (1 - 2 del) (m1 - m2 + p) B0[p, m1, m2])),
  C0i[cc2, 0, p_, p_, m1_, m1_, m2_] :> 1/(p ((m1 + m2 - p)^2 - 4 m1 m2)) ((-1 + del) (m1 (m2 - m1 + p) B0[0, 0, m1] + m2 (m1 - m2 + p) B0[0, 0, m2]) + ((-1 + del) (m1 - m2)^2 + (m1 + m2) p - del p^2) B0[p, m1, m2]),
  C0i[cc2, p_, 0, p_, m1_, m2_, m2_] :> 1/(p ((m1 + m2 - p)^2 - 4 m1 m2)) ((-1 + del) (m2 (m1 - m2 + p) B0[0, 0, m2] + m1 (m2 - m1 + p) B0[0, 0, m1]) + ((-1 + del) (m2 - m1)^2 + (m1 + m2) p - del p^2) B0[p, m1, m2]) } /.
  ToOldBRules;

Derivative[1, __][B0][ExtMomSq, m__] ^:= DB0[ExtMomSq, m];
Derivative[1, __][B1][ExtMomSq, m__] ^:= DB1[ExtMomSq, m];

amp = If[se == "h0h0p" || se == "HHHHp",
         D[amp, ExtMomSq],
         amp];

ExtMomSq = Piecewise[{{0, se == "h0h0p"}, {0, se == "HHHHp"}}, 0];

Put[amp, out];

Uninstall[$ReadFormHandle];
_EOF_
;;
esac

gzip $out.log

test -f $out

